---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>DarkSite</title>

  <link rel="stylesheet" href="/assets/styles.css" />
</head>

<body>

  <header>
    <nav>
      <h2>DarkSite</h2>

      <ul>
        <li><a href="#">Inicio</a></li>
        <li><a href="#">Servicios</a></li>
        <li><a href="#">Proyectos</a></li>
        <li><a href="#">Contacto</a></li>
      </ul>
    </nav>
  </header>

  <section class="hero">
    <h1>Página moderna en modo oscuro</h1>

    <p>
      Ejemplo de layout responsive utilizando HTML y CSS.
    </p>

    <a href="#" class="btn">Comenzar</a>
  </section>

  <section>
    <div class="container">

      <h2>Servicios</h2>

      <div class="cards">

        <div class="card">
          <h3>Diseño</h3>
          <p>Interfaces modernas y minimalistas.</p>
        </div>

        <div class="card">
          <h3>Frontend</h3>
          <p>Desarrollo web responsive y dinámico.</p>
        </div>

        <div class="card">
          <h3>Optimización</h3>
          <p>Mejoras de rendimiento y accesibilidad.</p>
        </div>

      </div>
    </div>
  </section>

  <footer>
    <p>© 2026 DarkSite</p>
  </footer>

</body>
</html>